# Application Settings
APP_NAME=CV Research Hub
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# CORS Origins (JSON array)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cv_research_hub
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1

# Celery
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3

# External API Keys (optional but recommended)
GITHUB_TOKEN=your_github_token_here
OPENAI_API_KEY=your_openai_api_key_here
HUGGINGFACE_TOKEN=your_huggingface_token_here
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_RESULTS_PER_CATEGORY=3
GEMINI_LOOKBACK_DAYS=7
GEMINI_MAX_RETRIES=5
GEMINI_REQUEST_DELAY_SECONDS=3

# Ingestion Settings
ARXIV_MAX_RESULTS_PER_QUERY=100
GITHUB_MAX_REPOS_PER_QUERY=50
PAPERS_WITH_CODE_MAX_RESULTS=100

# Scoring Weights
SCORE_RECENCY_WEIGHT=0.25
SCORE_CODE_WEIGHT=0.20
SCORE_SOURCE_WEIGHT=0.15
SCORE_IMPACT_WEIGHT=0.25
SCORE_CLARITY_WEIGHT=0.15

# Scheduling
DAILY_INGESTION_HOUR=6
GITHUB_REFRESH_INTERVAL_HOURS=6
