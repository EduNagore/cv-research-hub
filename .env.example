# App
APP_NAME=CV Research Hub
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production
LOG_LEVEL=info
SECRET_KEY=your_secret_key_here
PUBLIC_BASE_URL=https://yourdomain.com

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]

# Database
POSTGRES_USER=cvhub_user
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=cv_research_hub
DATABASE_URL=postgresql://cvhub_user:change_this_password@postgres:5432/cv_research_hub
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis / Celery
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/3

# External APIs
GITHUB_TOKEN=your_github_token_here
OPENAI_API_KEY=your_openai_api_key_here
HUGGINGFACE_TOKEN=your_huggingface_token_here
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_RESULTS_PER_CATEGORY=3
GEMINI_LOOKBACK_DAYS=7

# Ingestion
ARXIV_MAX_RESULTS_PER_QUERY=100
GITHUB_MAX_REPOS_PER_QUERY=50
PAPERS_WITH_CODE_MAX_RESULTS=100
DAILY_INGESTION_HOUR=6
GITHUB_REFRESH_INTERVAL_HOURS=6

# Scoring
SCORE_RECENCY_WEIGHT=0.25
SCORE_CODE_WEIGHT=0.20
SCORE_SOURCE_WEIGHT=0.15
SCORE_IMPACT_WEIGHT=0.25
SCORE_CLARITY_WEIGHT=0.15

# Frontend
VITE_API_URL=/api/v1
